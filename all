LJMP MAIN
ORG 000BH
CPL P1.2
MOV TL0, #0FFH
MOV TH0, #0EDH
RETI
ORG 30H
MAIN: MOV TMOD,#01h
MOV TL0, #0FFh
MOV TH0, #0EDH
MOV IE, #82H;
SETB TR0
HERE: SJMP HERE
END
